APP_NAME="Fualtec API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.midominio.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fualtec
DB_USERNAME=root
DB_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=midominio.com,.midominio.com
SESSION_DOMAIN=.midominio.com
FRONTEND_URL=https://midominio.com

QUEUE_CONNECTION=database
CACHE_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
FILESYSTEM_DISK=local
PRIVATE_PDF_PATH=privado/pdfs
CORS_ALLOWED_ORIGINS=https://midominio.com

BROADCAST_DRIVER=log
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mail.midominio.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=notificaciones@midominio.com
MAIL_FROM_NAME="Fualtec Energía"
